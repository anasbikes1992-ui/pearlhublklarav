APP_NAME=PearlHub
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.pearlhub.lk

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_TIMEZONE=Asia/Colombo

LOG_CHANNEL=stack
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=pearlhub
DB_USERNAME=pearlhub_user
DB_PASSWORD=CHANGE_ME

CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=CHANGE_ME
MAIL_PASSWORD=CHANGE_ME
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@pearlhub.lk
MAIL_FROM_NAME="PearlHub"

# WebXPay
WEBXPAY_MERCHANT_ID=
WEBXPAY_WEBHOOK_SECRET=
WEBXPAY_API_USERNAME=
WEBXPAY_API_PASSWORD=
WEBXPAY_SECRET_KEY=
WEBXPAY_ENC_METHOD=JCs3J+6oSz4V0LgE0zi/Bg==
WEBXPAY_CHECKOUT_URL=https://webxpay.com/index.php?route=checkout/billing
WEBXPAY_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# API/CORS settings
SANCTUM_STATEFUL_DOMAINS=pearlhub.lk,www.pearlhub.lk
SESSION_DOMAIN=.pearlhub.lk
FRONTEND_URL=https://pearlhub.lk

# Add payment/map/sms keys below
# STRIPE_KEY=
