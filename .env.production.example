# Production Environment Variables
# Copy this file to .env on your production server and fill in all values.
# NEVER commit real secrets to version control.

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_NAME=PearlHub
APP_ENV=production
APP_KEY=base64:REPLACE_WITH_GENERATED_KEY  # php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://pearlhublklarav.vercel.app

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=14

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# ---------------------------------------------------------------------------
# Database (PostgreSQL - use a managed service: AWS RDS, Railway, Neon, etc.)
# ---------------------------------------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=REPLACE_WITH_DB_HOST
DB_PORT=5432
DB_DATABASE=REPLACE_WITH_DB_NAME
DB_USERNAME=REPLACE_WITH_DB_USER
DB_PASSWORD=REPLACE_WITH_STRONG_DB_PASSWORD
DB_SSLMODE=require

# ---------------------------------------------------------------------------
# Session
# ---------------------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.pearlhublklarav.vercel.app
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# ---------------------------------------------------------------------------
# Broadcasting (Reverb / Ably / Pusher)
# ---------------------------------------------------------------------------
BROADCAST_CONNECTION=reverb

REVERB_APP_ID=REPLACE_WITH_REVERB_APP_ID
REVERB_APP_KEY=REPLACE_WITH_REVERB_APP_KEY
REVERB_APP_SECRET=REPLACE_WITH_REVERB_APP_SECRET
REVERB_HOST=REPLACE_WITH_REVERB_HOST
REVERB_PORT=443
REVERB_SCHEME=https

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ---------------------------------------------------------------------------
# Filesystem (AWS S3 recommended for production)
# ---------------------------------------------------------------------------
FILESYSTEM_DISK=s3

AWS_ACCESS_KEY_ID=REPLACE_WITH_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=REPLACE_WITH_AWS_SECRET_ACCESS_KEY
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=REPLACE_WITH_S3_BUCKET_NAME
AWS_USE_PATH_STYLE_ENDPOINT=false

# ---------------------------------------------------------------------------
# Queue
# ---------------------------------------------------------------------------
QUEUE_CONNECTION=database

# ---------------------------------------------------------------------------
# Cache / Redis
# ---------------------------------------------------------------------------
CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=REPLACE_WITH_REDIS_HOST
REDIS_PASSWORD=REPLACE_WITH_STRONG_REDIS_PASSWORD
REDIS_PORT=6379
REDIS_URL=tls://REPLACE_WITH_REDIS_HOST:6380  # use TLS in production

# ---------------------------------------------------------------------------
# Mail (use a transactional provider: Mailgun, SendGrid, AWS SES)
# ---------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=REPLACE_WITH_SMTP_HOST
MAIL_PORT=587
MAIL_USERNAME=REPLACE_WITH_SMTP_USER
MAIL_PASSWORD=REPLACE_WITH_SMTP_PASSWORD
MAIL_FROM_ADDRESS="no-reply@pearlhub.com"
MAIL_FROM_NAME="${APP_NAME}"

# ---------------------------------------------------------------------------
# Payment Gateways
# ---------------------------------------------------------------------------
PAYHERE_MERCHANT_ID=REPLACE_WITH_PAYHERE_MERCHANT_ID
PAYHERE_WEBHOOK_SECRET=REPLACE_WITH_PAYHERE_WEBHOOK_SECRET

WEBXPAY_MERCHANT_ID=REPLACE_WITH_WEBXPAY_MERCHANT_ID
WEBXPAY_WEBHOOK_SECRET=REPLACE_WITH_WEBXPAY_WEBHOOK_SECRET

DIALOG_GENIE_MERCHANT_ID=REPLACE_WITH_DIALOG_GENIE_MERCHANT_ID
DIALOG_GENIE_WEBHOOK_SECRET=REPLACE_WITH_DIALOG_GENIE_WEBHOOK_SECRET

# ---------------------------------------------------------------------------
# Search (Meilisearch Cloud or self-hosted with HTTPS)
# ---------------------------------------------------------------------------
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=https://REPLACE_WITH_MEILISEARCH_HOST
MEILISEARCH_KEY=REPLACE_WITH_MEILISEARCH_MASTER_KEY

# ---------------------------------------------------------------------------
# Next.js Frontend (public, safe to expose in browser)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=https://REPLACE_WITH_LARAVEL_API_URL
NEXT_PUBLIC_REVERB_APP_KEY=REPLACE_WITH_REVERB_APP_KEY
NEXT_PUBLIC_REVERB_HOST=REPLACE_WITH_REVERB_HOST
NEXT_PUBLIC_REVERB_PORT=443
NEXT_PUBLIC_REVERB_SCHEME=https
