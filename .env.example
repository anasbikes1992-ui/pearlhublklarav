APP_NAME=PearlHub
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=5

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database (MySQL) ───────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=pearlhub
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@pearlhub.lk"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ── Sanctum ────────────────────────────────────────────
# Comma-separated list of stateful domains (web clients using session cookies)
SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000

# ── CORS ───────────────────────────────────────────────
# The URL of the Next.js frontend (sets CORS allowed_origins)
FRONTEND_URL=http://localhost:3000

# ── Payments ───────────────────────────────────────────
PAYHERE_MERCHANT_ID=
PAYHERE_WEBHOOK_SECRET=

WEBXPAY_MERCHANT_ID=
WEBXPAY_WEBHOOK_SECRET=
WEBXPAY_API_USERNAME=
WEBXPAY_API_PASSWORD=
WEBXPAY_SECRET_KEY=
WEBXPAY_ENC_METHOD=JCs3J+6oSz4V0LgE0zi/Bg==
WEBXPAY_CHECKOUT_URL=https://webxpay.com/index.php?route=checkout/billing
WEBXPAY_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

DIALOG_GENIE_MERCHANT_ID=
DIALOG_GENIE_WEBHOOK_SECRET=

# ── Reverb (WebSocket) ─────────────────────────────────
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http

# ── Meilisearch (Search) ───────────────────────────────
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_KEY=
